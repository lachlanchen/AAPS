{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AAPS Edit Response",
  "type": "object",
  "required": ["source", "summary", "diagnostics"],
  "additionalProperties": false,
  "properties": {
    "source": {
      "type": "string",
      "description": "The complete updated .aaps source."
    },
    "summary": {
      "type": "string",
      "description": "One concise sentence describing the edit."
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}

