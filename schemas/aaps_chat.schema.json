{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AAPS Studio Chat Router Response",
  "type": "object",
  "required": ["mode", "route", "message", "source", "diagnostics"],
  "additionalProperties": false,
  "properties": {
    "mode": {
      "type": "string",
      "enum": ["reply", "edit"]
    },
    "route": {
      "type": "string"
    },
    "message": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
