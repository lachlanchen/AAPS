# Local AAPS Studio backend settings. Copy to .env and fill secrets locally.
# Do not commit real API keys.

AAPS_AGENT_PROVIDER=codex

# Codex wrapper defaults. The Studio settings panel can override these locally.
AAPS_CODEX_MODEL=gpt-5.3-codex
AAPS_CODEX_REASONING=medium
AAPS_CODEX_TIMEOUT=240

# DeepSeek OpenAI-compatible API. Current preferred DeepSeek model: deepseek-v4-pro.
AAPS_DEEPSEEK_BASE_URL=https://api.deepseek.com
AAPS_DEEPSEEK_MODEL=deepseek-v4-pro
AAPS_DEEPSEEK_TIMEOUT=180
AAPS_DEEPSEEK_API_KEY=

# Smoke-test backend routes without model calls.
AAPS_MOCK_CODEX=1
